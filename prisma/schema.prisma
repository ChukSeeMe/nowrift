generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgcrypto, pg_trgm, citext]
}

enum UserStatus {
  active
  suspended
  pending_verification
  deleted

  @@map("user_status")
}

enum RoleName {
  visitor
  contributor
  editor
  senior_editor
  admin
  super_admin

  @@map("role_name")
}

enum ArticleStatus {
  draft
  in_review
  approved
  published
  retracted
  archived

  @@map("article_status")
}

enum ImageProvider {
  source_og
  unsplash
  fal_ai
  pollinations
  css_fallback
  manual_upload

  @@map("image_provider")
}

enum AgentName {
  scraper
  synthesiser
  image_fetcher
  publisher
  social_poster
  seo_agent
  grant_monitor
  social_monitor
  social_replier
  social_community
  social_trend
  social_strategy
  tool_discoverer

  @@map("agent_name")
}

enum AgentStatus {
  queued
  running
  completed
  failed
  retrying
  cancelled

  @@map("agent_status")
}

enum JobPriority {
  low
  normal
  high
  critical

  @@map("job_priority")
}

enum SocialPlatform {
  x
  linkedin
  threads

  @@map("social_platform")
}

enum SocialPostStatus {
  draft
  scored
  scheduled
  posted
  failed
  cancelled

  @@map("social_post_status")
}

enum SocialPostFormat {
  hook_text
  thread
  document
  question
  trend
  news_card
  grant_alert
  community_reply

  @@map("social_post_format")
}

enum GrantStatus {
  open
  closing_soon
  closed
  awarded
  cancelled
  draft

  @@map("grant_status")
}

enum GrantChangeType {
  deadline_extended
  deadline_shortened
  amount_increased
  amount_decreased
  new_criteria
  status_changed
  new_round
  description_updated
  new_grant

  @@map("grant_change_type")
}

enum AlertFrequency {
  instant
  daily
  weekly

  @@map("alert_frequency")
}

enum AlertType {
  new_grant
  deadline_14_days
  deadline_48_hours
  grant_changed
  grant_awarded

  @@map("alert_type")
}

enum AlertDeliveryStatus {
  pending
  sent
  failed
  suppressed

  @@map("alert_delivery_status")
}

enum SubscriberStatus {
  active
  unsubscribed
  bounced
  complained
  pending

  @@map("subscriber_status")
}

enum IssueStatus {
  draft
  scheduled
  sending
  sent
  cancelled

  @@map("issue_status")
}

enum SponsorStatus {
  prospect
  active
  paused
  churned

  @@map("sponsor_status")
}

enum PaymentStatus {
  pending
  invoiced
  paid
  overdue
  cancelled

  @@map("payment_status")
}

enum AuditAction {
  article_created             @map("article.created")
  article_submitted           @map("article.submitted")
  article_approved            @map("article.approved")
  article_published           @map("article.published")
  article_retracted           @map("article.retracted")
  article_deleted             @map("article.deleted")
  user_created                @map("user.created")
  user_suspended              @map("user.suspended")
  user_role_changed           @map("user.role_changed")
  user_password_changed       @map("user.password_changed")
  user_totp_enabled           @map("user.totp_enabled")
  user_totp_disabled          @map("user.totp_disabled")
  admin_config_changed        @map("admin.config_changed")
  grant_created               @map("grant.created")
  grant_published             @map("grant.published")
  grant_status_changed        @map("grant.status_changed")
  sponsor_created             @map("sponsor.created")
  sponsor_payment_received    @map("sponsor.payment_received")
  agent_config_changed        @map("agent.config_changed")
  token_revoked               @map("token.revoked")

  @@map("audit_action")
}

model User {
  id                    String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email                 String             @unique @db.Citext
  password_hash         String
  display_name          String?            @db.VarChar(100)
  avatar_url            String?
  status                UserStatus         @default(pending_verification)
  totp_enabled          Boolean            @default(false)
  totp_secret           String?
  failed_login_attempts Int                @default(0)
  locked_until          DateTime?          @db.Timestamptz
  last_login_at         DateTime?          @db.Timestamptz
  last_login_ip         String?            @db.Inet
  created_at            DateTime           @default(now()) @db.Timestamptz
  updated_at            DateTime           @default(now()) @db.Timestamptz

  // Relations
  user_roles            UserRole[]         @relation("UserRoles")
  assigned_roles        UserRole[]         @relation("AssignedBy")
  invite_tokens_created InviteToken[]      @relation("CreatedBy")
  invite_tokens_used    InviteToken[]      @relation("UsedBy")
  refresh_tokens        RefreshToken[]
  totp_recovery_codes   TotpRecoveryCode[]
  articles_created      Article[]          @relation("CreatedBy")
  articles_approved     Article[]          @relation("ApprovedBy")
  articles_retracted    Article[]          @relation("RetractedBy")
  content_reports       ContentReport[]    @relation("ReportedBy")
  content_resolutions   ContentReport[]    @relation("ResolvedBy")
  agent_configs_updated AgentConfig[]
  sponsors_created      Sponsor[]
  audit_logs            AuditLog[]
  login_attempts        LoginAttempt[]
  rate_limit_events     RateLimitEvent[]
  blocked_ips           IpBlocklist[]
  admin_sessions        AdminSession[]
  grants_created        Grant[]            @relation("GrantsCreatedBy")
  grants_published      Grant[]            @relation("GrantsPublishedBy")
  newsletter_issues     NewsletterIssue[]

  @@map("users")
}

model Role {
  id              String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            RoleName    @unique
  description     String
  permissions     Json        @default("[]")
  hierarchy_level Int
  created_at      DateTime    @default(now()) @db.Timestamptz

  // Relations
  user_roles      UserRole[]
  invite_tokens   InviteToken[]

  @@map("roles")
}

model UserRole {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id     String    @db.Uuid
  role_id     String    @db.Uuid
  assigned_by String?   @db.Uuid
  assigned_at DateTime  @default(now()) @db.Timestamptz
  expires_at  DateTime? @db.Timestamptz
  notes       String?

  // Relations
  user        User      @relation("UserRoles", fields: [user_id], references: [id], onDelete: Cascade)
  role        Role      @relation(fields: [role_id], references: [id], onDelete: Restrict)
  assigner    User?     @relation("AssignedBy", fields: [assigned_by], references: [id], onDelete: SetNull)

  @@unique([user_id, role_id])
  @@map("user_roles")
}

model InviteToken {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  token      String    @unique @default(dbgenerated("encode(gen_random_bytes(32), 'hex')"))
  email      String    @db.Citext
  role_id    String    @db.Uuid
  created_by String    @db.Uuid
  used       Boolean   @default(false)
  used_at    DateTime? @db.Timestamptz
  used_by    String?   @db.Uuid
  expires_at DateTime  @default(dbgenerated("(now() + '7 days'::interval)")) @db.Timestamptz
  created_at DateTime  @default(now()) @db.Timestamptz

  // Relations
  role      Role  @relation(fields: [role_id], references: [id], onDelete: Restrict)
  creator   User  @relation("CreatedBy", fields: [created_by], references: [id], onDelete: Cascade)
  user_used User? @relation("UsedBy", fields: [used_by], references: [id], onDelete: SetNull)

  @@map("invite_tokens")
}

model RefreshToken {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id        String    @db.Uuid
  token_hash     String    @unique
  ip_address     String?   @db.Inet
  user_agent     String?
  revoked        Boolean   @default(false)
  revoked_at     DateTime? @db.Timestamptz
  revoked_reason String?
  expires_at     DateTime  @default(dbgenerated("(now() + '7 days'::interval)")) @db.Timestamptz
  created_at     DateTime  @default(now()) @db.Timestamptz

  // Relations
  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model TotpRecoveryCode {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String    @db.Uuid
  code_hash  String
  used       Boolean   @default(false)
  used_at    DateTime? @db.Timestamptz
  created_at DateTime  @default(now()) @db.Timestamptz

  // Relations
  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("totp_recovery_codes")
}

model Channel {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String    @unique @db.VarChar(100)
  slug        String    @unique @db.VarChar(100)
  description String?
  color_hex   String    @default("#FF3D3D") @db.VarChar(7)
  icon_name   String?   @db.VarChar(100)
  is_active   Boolean   @default(true)
  sort_order  Int       @default(0)
  created_at  DateTime  @default(now()) @db.Timestamptz

  // Relations
  articles Article[]

  @@map("channels")
}

model Source {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String   @db.VarChar(200)
  rss_url         String?  @unique
  domain          String   @unique @db.VarChar(255)
  homepage_url    String?
  trust_score     Int      @default(70)
  is_active       Boolean  @default(true)
  check_frequency String   @default("every_2h") @db.VarChar(20)
  last_checked_at DateTime? @db.Timestamptz
  last_item_at    DateTime? @db.Timestamptz
  total_items     Int      @default(0)
  geo_region      String   @default("global") @db.VarChar(50)
  notes           String?
  created_at      DateTime @default(now()) @db.Timestamptz
  updated_at      DateTime @default(now()) @db.Timestamptz

  // Relations
  article_sources ArticleSource[]
  scrape_queue    ScrapeQueue[]

  @@map("sources")
}

model Article {
  id                 String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug               String        @unique @db.VarChar(500)
  headline           String
  deck               String?
  body_html          String?
  so_what_dev        String?
  so_what_security   String?
  so_what_founders   String?
  so_what_creators   String?
  so_what_data       String?
  status             ArticleStatus @default(draft)
  is_breaking        Boolean       @default(false)
  is_featured        Boolean       @default(false)
  relevance_score    Float?
  ai_model_used      String?       @db.VarChar(100)
  synthesis_cost_usd Decimal       @default(0) @db.Decimal(10, 6)
  channel_id         String?       @db.Uuid
  created_by         String?       @db.Uuid
  approved_by        String?       @db.Uuid
  retracted_by       String?       @db.Uuid
  meta_title         String?       @db.VarChar(70)
  meta_description   String?       @db.VarChar(160)
  og_image_url       String?
  canonical_url      String?
  json_ld            Json?
  view_count         Int           @default(0)
  share_count        Int           @default(0)
  published_at       DateTime?     @db.Timestamptz
  retracted_at       DateTime?     @db.Timestamptz
  created_at         DateTime      @default(now()) @db.Timestamptz
  updated_at         DateTime      @default(now()) @db.Timestamptz
  
  // Deep Dive fields
  content_tier       String        @default("daily") @db.VarChar(20)
  deep_dive_format   String?       @db.VarChar(20)
  related_sector     String?       @db.VarChar(50)
  source_article_ids String[]      @db.Uuid
  is_human_authored  Boolean       @default(false)
  read_time_minutes  Int?
  sectors            String[]      @db.VarChar(50)
  writing_style      String?       @db.VarChar(30)

  // Relations
  channel             Channel?            @relation(fields: [channel_id], references: [id], onDelete: SetNull)
  creator             User?               @relation("CreatedBy", fields: [created_by], references: [id], onDelete: SetNull)
  approver            User?               @relation("ApprovedBy", fields: [approved_by], references: [id], onDelete: SetNull)
  retractor           User?               @relation("RetractedBy", fields: [retracted_by], references: [id], onDelete: SetNull)
  sources             ArticleSource[]
  audit_record        AigenAuditRecord?
  tags                ArticleTag[]
  images              ArticleImage[]
  scrape_queue        ScrapeQueue[]
  content_reports     ContentReport[]
  synthesis_jobs      SynthesisJob[]
  social_posts        SocialPost[]
  issue_articles      IssueArticle[]
  sector_coverage_log SectorCoverageLog[]

  @@map("articles")
}

model SectorCoverageLog {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sector     String   @db.VarChar(50)
  article_id String?  @db.Uuid
  covered_at DateTime @default(now()) @db.Timestamptz

  // Relations
  article    Article? @relation(fields: [article_id], references: [id], onDelete: SetNull)

  @@map("sector_coverage_log")
  @@index([sector, covered_at(sort: Desc)])
}


model ArticleSource {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  article_id       String   @db.Uuid
  source_id        String?  @db.Uuid
  source_url       String
  source_title     String?
  source_domain    String?  @db.VarChar(255)
  similarity_score Float?
  was_primary      Boolean  @default(false)
  scraped_at       DateTime @default(now()) @db.Timestamptz

  // Relations
  article Article @relation(fields: [article_id], references: [id], onDelete: Cascade)
  source  Source? @relation(fields: [source_id], references: [id], onDelete: SetNull)

  @@map("article_sources")
}

model AigenAuditRecord {
  id                   String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  article_id           String    @unique @db.Uuid
  model_used           String    @db.VarChar(100)
  synthesis_prompt_hash String?
  source_count         Int       @default(0)
  source_urls          Json      @default("[]")
  max_similarity_score Float     @default(0)
  copyright_passed     Boolean   @default(false)
  compliance_notes     String?
  r2_audit_path        String?
  ingested_at          DateTime  @default(now()) @db.Timestamptz
  published_at         DateTime? @db.Timestamptz

  // Relations
  article Article @relation(fields: [article_id], references: [id], onDelete: Cascade)

  @@map("aigen_audit_records")
}

model Tag {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String       @unique @db.VarChar(100)
  slug        String       @unique @db.VarChar(100)
  usage_count Int          @default(0)
  created_at  DateTime     @default(now()) @db.Timestamptz

  // Relations
  articles ArticleTag[]

  @@map("tags")
}

model ArticleTag {
  article_id String @db.Uuid
  tag_id     String @db.Uuid

  // Relations
  article Article @relation(fields: [article_id], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tag_id], references: [id], onDelete: Cascade)

  @@id([article_id, tag_id])
  @@map("article_tags")
}

model ArticleImage {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  article_id      String        @db.Uuid
  image_url       String
  image_type      String        @default("card") @db.VarChar(20)
  provider        ImageProvider @default(source_og)
  alt_text        String?
  attribution     String?
  width           Int?
  height          Int?
  file_size_bytes Int?
  is_verified     Boolean       @default(false)
  verified_at     DateTime?     @db.Timestamptz
  r2_path         String?
  created_at      DateTime      @default(now()) @db.Timestamptz

  // Relations
  article Article @relation(fields: [article_id], references: [id], onDelete: Cascade)

  @@map("article_images")
}

model ScrapeQueue {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  url             String    @unique
  source_id       String?   @db.Uuid
  source_name     String?   @db.VarChar(200)
  raw_title       String?
  raw_excerpt     String?
  raw_og_image    String?
  status          String    @default("pending") @db.VarChar(20)
  relevance_score Float?
  rejection_reason String?
  retry_count     Int       @default(0)
  agent_run_id    String?   @db.Uuid
  article_id      String?   @db.Uuid
  scraped_at      DateTime  @default(now()) @db.Timestamptz
  processed_at    DateTime? @db.Timestamptz

  // Relations
  source  Source?  @relation(fields: [source_id], references: [id], onDelete: SetNull)
  article Article? @relation(fields: [article_id], references: [id], onDelete: SetNull)

  @@map("scrape_queue")
}

model ContentReport {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  article_id      String    @db.Uuid
  reported_by     String?   @db.Uuid
  reporter_email  String?   @db.Citext
  reason          String    @db.VarChar(100)
  description     String?
  status          String    @default("open") @db.VarChar(20)
  resolved_by     String?   @db.Uuid
  resolution_note String?
  created_at      DateTime  @default(now()) @db.Timestamptz
  resolved_at     DateTime? @db.Timestamptz

  // Relations
  article  Article @relation(fields: [article_id], references: [id], onDelete: Cascade)
  reporter User?   @relation("ReportedBy", fields: [reported_by], references: [id], onDelete: SetNull)
  resolver User?   @relation("ResolvedBy", fields: [resolved_by], references: [id], onDelete: SetNull)

  @@map("content_reports")
}

model AgentConfig {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  agent_name      AgentName @unique
  is_enabled      Boolean   @default(true)
  config          Json      @default("{}")
  cron_expression String?   @db.VarChar(100)
  last_updated_by String?   @db.Uuid
  updated_at      DateTime  @default(now()) @db.Timestamptz

  // Relations
  updater User? @relation(fields: [last_updated_by], references: [id], onDelete: SetNull)

  @@map("agent_config")
}

model AgentRun {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  agent_name      AgentName
  status          AgentStatus  @default(queued)
  priority        JobPriority  @default(normal)
  triggered_by    String       @default("cron") @db.VarChar(50)
  items_processed Int          @default(0)
  items_succeeded Int          @default(0)
  items_failed    Int          @default(0)
  input_tokens    Int          @default(0)
  output_tokens   Int          @default(0)
  cost_usd        Decimal      @default(0) @db.Decimal(10, 6)
  error_message   String?
  error_stack     String?
  metadata        Json         @default("{}")
  started_at      DateTime?    @db.Timestamptz
  completed_at    DateTime?    @db.Timestamptz
  created_at      DateTime     @default(now()) @db.Timestamptz

  // Relations
  synthesis_jobs SynthesisJob[]
  social_posts   SocialPost[]
  grant_changes  GrantChange[]

  @@map("agent_runs")
}

model SynthesisJob {
  id                   String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  article_id           String?   @db.Uuid
  agent_run_id         String?   @db.Uuid
  model_used           String    @db.VarChar(100)
  prompt_version       String    @default("v1") @db.VarChar(20)
  input_tokens         Int       @default(0)
  output_tokens        Int       @default(0)
  cost_usd             Decimal   @default(0) @db.Decimal(10, 6)
  max_similarity_score Float     @default(0)
  source_count         Int       @default(0)
  source_urls          Json      @default("[]")
  status               String    @default("pending") @db.VarChar(20)
  rejection_reason     String?
  duration_ms          Int?
  created_at           DateTime  @default(now()) @db.Timestamptz

  // Relations
  article   Article?  @relation(fields: [article_id], references: [id], onDelete: Cascade)
  agent_run AgentRun? @relation(fields: [agent_run_id], references: [id], onDelete: SetNull)

  @@map("synthesis_jobs")
}

model SocialPost {
  id                String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  article_id        String?          @db.Uuid
  grant_id          String?          @db.Uuid
  agent_run_id      String?          @db.Uuid
  platform          SocialPlatform
  format            SocialPostFormat @default(hook_text)
  status            SocialPostStatus @default(draft)
  content_main      String
  content_reply     String?
  image_url         String?
  link_url          String?
  content_score     Int?
  ab_variant        String?          @db.Char(1)
  external_post_id  String?
  external_reply_id String?
  scheduled_at      DateTime?        @db.Timestamptz
  posted_at         DateTime?        @db.Timestamptz
  failed_at         DateTime?        @db.Timestamptz
  failure_reason    String?
  impressions       Int              @default(0)
  reach             Int              @default(0)
  replies           Int              @default(0)
  likes             Int              @default(0)
  reposts           Int              @default(0)
  bookmarks         Int              @default(0)
  link_clicks       Int              @default(0)
  profile_visits    Int              @default(0)
  velocity_30min    Json             @default("{}")
  created_at        DateTime         @default(now()) @db.Timestamptz
  updated_at        DateTime         @default(now()) @db.Timestamptz

  // Relations
  article   Article?       @relation(fields: [article_id], references: [id], onDelete: SetNull)
  grant     Grant?         @relation(fields: [grant_id], references: [id], onDelete: SetNull)
  agent_run AgentRun?      @relation(fields: [agent_run_id], references: [id], onDelete: SetNull)
  metrics   SocialMetric[]
  replies_  SocialReply[]

  @@map("social_posts")
}

model SocialMetric {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  post_id         String   @db.Uuid
  snapshot_at     DateTime @default(now()) @db.Timestamptz
  snapshot_type   String   @default("30min") @db.VarChar(20)
  impressions     Int      @default(0)
  reach           Int      @default(0)
  replies         Int      @default(0)
  likes           Int      @default(0)
  reposts         Int      @default(0)
  bookmarks       Int      @default(0)
  link_clicks     Int      @default(0)
  profile_visits  Int      @default(0)
  engagement_rate Float    @default(dbgenerated("0.0"))

  // Relations
  post SocialPost @relation(fields: [post_id], references: [id], onDelete: Cascade)

  @@map("social_metrics")
}

model SocialReply {
  id                 String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  post_id            String?        @db.Uuid
  platform           SocialPlatform
  direction          String         @db.VarChar(10)
  external_reply_id  String?
  parent_reply_id    String?
  author_handle      String?
  content            String
  our_response       String?
  response_posted_at DateTime?      @db.Timestamptz
  response_score     Int?
  sentiment          String?        @db.VarChar(20)
  was_mention        Boolean        @default(false)
  created_at         DateTime       @default(now()) @db.Timestamptz

  // Relations
  post SocialPost? @relation(fields: [post_id], references: [id], onDelete: Cascade)

  @@map("social_replies")
}

model PlatformPattern {
  id                  String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  platform            SocialPlatform
  week_start          DateTime       @db.Date
  best_post_times     Json           @default("[]")
  best_formats        Json           @default("[]")
  best_topics         Json           @default("[]")
  best_hooks          Json           @default("[]")
  avg_content_score   Float?
  avg_engagement_rate Float?
  follower_count      Int?
  follower_delta      Int?
  top_posts           Json           @default("[]")
